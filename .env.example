APP_PORT=5000
APP_ENV=development

# Database (Supabase Pool Connection)
DB_HOST=your-supabase-project.pooler.supabase.com
DB_PORT=5432
DB_USER=postgres.your-project-ref
DB_PASSWORD=your-database-password
DB_NAME=postgres

# Supabase Storage
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
STORAGE_BUCKET_VIDEOS=videos
STORAGE_BUCKET_THUMBNAILS=thumbnails
STORAGE_BUCKET_ASSETS=assets

# JWT (Change these for production!)
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_EXPIRE_HOURS=24
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this-in-production
JWT_REFRESH_EXPIRE_HOURS=168

# AI Service
AI_SERVICE_URL=http://localhost:8000

# AI Provider API Keys
LTX_API_KEY=your-ltx-api-key-here
RUNWAY_API_KEY=your-runway-api-key-here
WAN2_API_KEY=your-wan2-api-key-here
