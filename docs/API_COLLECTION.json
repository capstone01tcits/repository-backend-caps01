                "value": "Bearer {{access_token}}"
              }
            ]
          }
        },
        {
          "name": "Delete Project",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/api/projects/{{project_id}}",
              "protocol": "http",
              "host": ["{{base_url}}"],
              "path": ["api", "projects", "{{project_id}}"]
