{
  "info": {
    "name": "AI Video Generation Platform - Final v5.0",
    "version": "5.0.0",
    "description": "Updated May 2026 - Google Veo 3.1 Lite Integration with Atomic Linear Flow. All routes verified against Backend v1.0.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5000" },
    { "key": "access_token", "value": "" },
    { "key": "refresh_token", "value": "" },
    { "key": "project_id", "value": "" },
    { "key": "storyboard_id", "value": "" },
    { "key": "job_id", "value": "" },
    { "key": "scene_id", "value": "" },
    { "key": "user_id", "value": "" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/health"
      }
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"secure123456\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"secure123456\"\n}"
            }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "Initialize Project (Atomic)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/projects/initialize",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"institution_name\": \"SMA Negeri 1 Jakarta\",\n  \"school_level\": \"SMA\",\n  \"event_content\": \"Penerimaan Siswa Baru\",\n  \"tone_of_voice\": \"Santai & Ramah\",\n  \"selected_key_message\": \"Bergabunglah dengan komunitas pembelajar yang dinamis\",\n  \"video_duration\": \"6 detik\",\n  \"selected_theme\": \"Tur Kampus Sinematik\"\n}"
            }
          }
        },
        {
          "name": "List Projects",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/projects",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        }
      ]
    },
    {
      "name": "Videos",
      "item": [
        {
          "name": "Generate Video",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/videos/generate",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"project_id\": \"{{project_id}}\",\n  \"storyboard_id\": \"{{storyboard_id}}\"\n}"
            }
          }
        },
        {
          "name": "Get Video Status (Polling)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/videos/{{job_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "Download Video",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/videos/download/{{job_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Add Credits",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/admin/credits",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"{{user_id}}\",\n  \"amount\": 100\n}"
            }
          }
        }
      ]
    }
  ]
}