                "value": "Bearer {{access_token}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Storyboard",
      "item": [
        {
          "name": "Generate Storyboard Templates",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = res.body;",
                  "if (jsonData.data && jsonData.data.templates && jsonData.data.templates.length > 0) {",
                  "  bru.setVar('storyboard_id', jsonData.data.templates[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/storyboard/templates/generate",
              "protocol": "http",
              "host": ["{{base_url}}"],
              "path": ["api", "storyboard", "templates", "generate"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"project_id\": \"{{project_id}}\",\n  \"video_duration\": 30\n}"
            }
          }
        },
        {
          "name": "Create Manual Storyboard",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = res.body;",
                  "if (jsonData.data && jsonData.data.id) {",
                  "  bru.setVar('storyboard_id', jsonData.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/storyboard/create",
              "protocol": "http",
              "host": ["{{base_url}}"],
              "path": ["api", "storyboard", "create"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"project_id\": \"{{project_id}}\",\n  \"title\": \"Custom Storyboard\",\n  \"description\": \"Manually created storyboard\",\n  \"total_duration\": 30,\n  \"style\": \"Dynamic\",\n  \"sections\": [\n    {\n      \"section_type\": \"hook\",\n      \"content\": \"Hook content here\",\n      \"duration\": 10\n    },\n    {\n      \"section_type\": \"value\",\n      \"content\": \"Value proposition here\",\n      \"duration\": 10\n    },\n    {\n      \"section_type\": \"cta\",\n      \"content\": \"Call to action here\",\n      \"duration\": 10\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Delete Storyboard",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/api/storyboard/{{storyboard_id}}",
              "protocol": "http",
              "host": ["{{base_url}}"],
              "path": ["api", "storyboard", "{{storyboard_id}}"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ]
          }
        },
        {
          "name": "Restore Storyboard",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/storyboard/{{storyboard_id}}/restore",
              "protocol": "http",
              "host": ["{{base_url}}"],
              "path": ["api", "storyboard", "{{storyboard_id}}", "restore"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ]
          }
        }
      ]
    },
