          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/projects/initialize",
              "protocol": "http",
              "host": ["{{base_url}}"],
              "path": ["api", "projects", "initialize"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"institution_name\": \"SMA Negeri 1 Jakarta\",\n  \"institution_history\": \"Sekolah terkemuka dengan program pendidikan berkualitas tinggi\",\n  \"school_level\": \"SMA\",\n  \"offered_degrees\": \"IPA, IPS, Bahasa\",\n  \"event_content\": \"Penerimaan Siswa Baru\",\n  \"tone_of_voice\": \"Santai & Ramah\",\n  \"selected_key_message\": \"Bergabunglah dengan komunitas pembelajar yang dinamis\",\n  \"video_duration\": \"15 detik\",\n  \"prompt\": \"Video yang engaging untuk Gen Z\",\n  \"selected_theme\": \"Tur Kampus Sinematik\",\n  \"editable_copywriting\": \"Halo calon siswa baru!\",\n  \"editable_hashtags\": \"#SMANegeri1Jakarta\",\n  \"logo_base64\": \"\",\n  \"env_base64\": \"\",\n  \"document_base64\": \"\"\n}"
            }
          }
        },
        {
          "name": "List Projects",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/projects/",
              "protocol": "http",
              "host": ["{{base_url}}"],
              "path": ["api", "projects", ""]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ]
          }
        },
        {
          "name": "Get Project",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/projects/{{project_id}}",
              "protocol": "http",
