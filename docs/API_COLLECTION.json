{
  "info": {
    "name": "AI Video Generation Platform - Active Endpoints",
    "version": "3.1.0",
    "description": "Updated May 2026 - New Storyboard Template Generator with 4 style variations (Dynamic, Narrative, Energetic, Minimalist). Manual storyboard composition with 3-section structure (Hook/Value/CTA). Flexible video duration handling (15-300 seconds).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "refresh_token",
      "value": ""
    },
    {
      "key": "project_id",
      "value": ""
    },
    {
      "key": "storyboard_id",
      "value": ""
    },
    {
      "key": "video_id",
      "value": ""
    },
    {
      "key": "scene_id",
      "value": ""
    },
    {
      "key": "user_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/health",
          "protocol": "http",
          "host": ["{{base_url}}"],
          "path": ["health"]
        },
        "header": []
      }
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = res.body;",
                  "if (jsonData.data && jsonData.data.user && jsonData.data.user.id) {",
                  "  bru.setVar('user_id', jsonData.data.user.id);",
                  "}",
                  "if (jsonData.data && jsonData.data.access_token) {",
                  "  bru.setVar('access_token', jsonData.data.access_token);",
                  "}",
                  "if (jsonData.data && jsonData.data.refresh_token) {",
                  "  bru.setVar('refresh_token', jsonData.data.refresh_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "protocol": "http",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"secure123456\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = res.body;",
                  "if (jsonData.data && jsonData.data.access_token) {",
                  "  bru.setVar('access_token', jsonData.data.access_token);",
                  "}",
                  "if (jsonData.data && jsonData.data.refresh_token) {",
                  "  bru.setVar('refresh_token', jsonData.data.refresh_token);",
                  "}",
                  "if (jsonData.data && jsonData.data.user && jsonData.data.user.id) {",
                  "  bru.setVar('user_id', jsonData.data.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "protocol": "http",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"secure123456\"\n}"
            }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/auth/me",
              "protocol": "http",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "me"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ]
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/auth/change-password",
              "protocol": "http",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "change-password"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"old_password\": \"secure123456\",\n  \"new_password\": \"newsecure123456\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = res.body;",
                  "if (jsonData.data && jsonData.data.access_token) {",
                  "  bru.setVar('access_token', jsonData.data.access_token);",
                  "}",
                  "if (jsonData.data && jsonData.data.refresh_token) {",
                  "  bru.setVar('refresh_token', jsonData.data.refresh_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/auth/refresh",
              "protocol": "http",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "refresh"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            }
          }
        },
        {
          "name": "Delete Account",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/api/auth/account",
              "protocol": "http",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "account"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "Initialize Project (from FE Wizard)",
          "event": [
            {
              "listen": "test",
