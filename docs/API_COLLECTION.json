{
  "info": {
    "name": "AI Video Gen - Final v5.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/register",
            "body": {
              "mode": "json",
              "json": "{\n  \"name\": \"Test User\",\n  \"email\": \"user@example.com\",\n  \"password\": \"pass123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/login",
            "body": {
              "mode": "json",
              "json": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"pass123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "Initialize Project (Atomic)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/projects/initialize",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "json",
              "json": "{\n  \"institution_name\": \"Kampus ITS\",\n  \"school_level\": \"Perguruan Tinggi\",\n  \"event_content\": \"Dies Natalis\",\n  \"tone_of_voice\": \"Profesional & Formal\",\n  \"selected_key_message\": \"Membangun Masa Depan\",\n  \"selected_theme\": \"Tur Kampus Sinematik\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Videos",
      "item": [
        {
          "name": "Generate Video",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/videos/generate",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "json",
              "json": "{\n  \"project_id\": \"{{project_id}}\",\n  \"storyboard_id\": \"{{storyboard_id}}\"\n}"
            }
          }
        },
        {
          "name": "Get Video Status (Polling)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/videos/{{job_id}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "base_url", "value": "http://localhost:5000" },
    { "key": "access_token", "value": "" },
    { "key": "project_id", "value": "" },
    { "key": "storyboard_id", "value": "" },
    { "key": "job_id", "value": "" }
  ]
}