                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ]
          }
        },
        {
          "name": "Restore Project",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/projects/{{project_id}}/restore",
              "protocol": "http",
