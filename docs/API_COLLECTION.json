                        "body": {
                            "mode": "raw",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            },
                            "raw": "{\n  \"institution_name\": \"SMA Negeri 1 Jakarta\",\n  \"institution_history\": \"Sekolah terkemuka dengan program pendidikan berkualitas tinggi\",\n  \"school_level\": \"Senior High School\",\n  \"offered_degrees\": \"\",\n  \"event_content\": \"Penerimaan Mahasiswa Baru\",\n  \"tone_of_voice\": \"Santai & Ramah\",\n  \"selected_key_message\": \"Bergabunglah dengan keluarga besar kami\",\n  \"video_duration\": \"15 detik\",\n  \"prompt\": \"\",\n  \"selected_theme\": \"Tur Kampus Sinematik\",\n  \"editable_copywriting\": \"Halo generasi masa depan! Bergabunglah dengan keluarga besar kami dan wujudkan impianmu bersama SMA Negeri 1 Jakarta.\",\n  \"editable_hashtags\": \"#SMANegeri1Jakarta #PenerimaanMahasiswaBaru #Pendidikan #KampusImpian\"\n}"
                        }
                    }
                },
                {
                    "name": "List Projects",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var jsonData = res.body;",
                                    "if (jsonData.data && Array.isArray(jsonData.data) && jsonData.data.length > 0) {",
                                    "  bru.setVar('project_id', jsonData.data[0].id);",
                                    "}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{base_url}}/api/projects",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "projects"
                            ]
                        },
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{access_token}}"
                            }
                        ]
                    }
                },
                {
                    "name": "Get Project by ID",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{base_url}}/api/projects/{{project_id}}",
                            "host": [
