# Server Config
HOST=127.0.0.1
PORT=8000
DEBUG=True

# Wavespeed API (Primary Video Provider)
WAVESPEED_API_KEY=your-wavespeed-api-key-here
WAVESPEED_MODEL=google/veo3.1-lite/text-to-video

# Output Storage (Local Fallback)
VIDEO_OUTPUT_DIR=outputs/videos
VIDEO_BASE_URL=http://127.0.0.1:8000/video/
