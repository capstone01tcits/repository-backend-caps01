# Wavespeed AI — Primary provider
WAVESPEED_API_KEY=your-wavespeed-api-key-here
WAVESPEED_MODEL=google/veo3.1-lite/text-to-video

# Output dirs
VIDEO_OUTPUT_DIR=outputs/videos
REPORT_DIR=outputs/reports

# Active provider (wavespeed = primary)
ACTIVE_PROVIDER=wavespeed
ACTIVE_MODEL=google/veo3.1-lite/text-to-video
ACTIVE_DURATION=10
ACTIVE_RATIO=16:9

# Service config
AI_SERVICE_HOST=127.0.0.1
AI_SERVICE_PORT=8000
